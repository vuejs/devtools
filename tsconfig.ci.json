{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "packages/shared",
    "packages/devtools-kit",
    "packages/devtools-api",
    "packages/core"
  ],
  "exclude": [
    "packages/devtools-kit/__tests__",
    "**/vite/src/overlay/**",
    "**/dist/**",
    "**/node_modules/**",
    "**/**/*.js"
  ]
}
